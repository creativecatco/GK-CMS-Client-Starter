{
    "name": "creativecatco/gk-cms-core",
    "description": "GKeys CMS — A powerful AI-ready content management system by Growth Keys. Provides page management, blog, media library, inline editing, site settings, user roles, SEO, and a Filament admin panel.",
    "type": "library",
    "version": "0.8.6.2",
    "license": "proprietary",
    "keywords": [
        "laravel",
        "cms",
        "filament",
        "gkeys",
        "growth-keys",
        "content-management",
        "ai-cms"
    ],
    "authors": [
        {
            "name": "Growth Keys",
            "email": "support@growthkeys.com",
            "homepage": "https://growthkeys.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "illuminate/view": "^10.0|^11.0",
        "illuminate/mail": "^10.0|^11.0",
        "illuminate/notifications": "^10.0|^11.0",
        "filament/filament": "^3.0",
        "filament/forms": "^3.0",
        "filament/tables": "^3.0",
        "filament/notifications": "^3.0",
        "filament/widgets": "^3.0",
        "livewire/livewire": "^3.0",
        "spatie/laravel-sluggable": "^3.6",
        "symfony/dom-crawler": "^7.4",
        "symfony/css-selector": "^7.4"
    },
    "autoload": {
        "psr-4": {
            "CreativeCatCo\\GkCmsCore\\": "src/",
            "CreativeCatCo\\GkCmsCore\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CreativeCatCo\\GkCmsCore\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CreativeCatCo\\GkCmsCore\\CmsCoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
